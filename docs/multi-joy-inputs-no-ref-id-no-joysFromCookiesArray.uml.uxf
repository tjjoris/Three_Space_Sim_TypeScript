    <panel_attributes>JoyAxisInputDiffValueReporter
--
-axisId:int
-joyId:int
-axisValue:float
-diff:float
-THRESHOLD:float
--
+constructor(axisId:int, threshold:float)
+calculateDifference() - reads the joystick axis, and finds 
the difference between the old axis value and the new one.
+isDiffAboveThreshold():bool
+isDiffGreater(biggestDifference: float):bool -Compares the 
passed diff with this one, if this one is greater, true.
+getAxis():int
+getDifference(): float
+getJoyId():int</panel_attributes>
